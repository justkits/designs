{
  "extends": "@justkits/tsconfig/base.json",
  "compilerOptions": {
    "types": ["vitest/globals", "node"],
    "paths": {
      "@lib/*": ["./src/lib/*"],
      "@converter/*": ["./src/converter/*"],
      "@cli/*": ["./src/cli/*"],
      "@tests/*": ["./tests/*"]
    }
  },
  "include": [
    "src",
    "tests",
    "eslint.config.ts",
    "vitest.config.ts",
    "tsup.config.ts"
  ],
  "exclude": ["dist", "node_modules"]
}
